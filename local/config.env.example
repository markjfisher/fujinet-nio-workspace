# Copy this file to local/config.env and edit for machine-specific overrides.
# local/config.env is ignored by git.

# Build against an active working tree outside the workspace submodule clone:
# export FUJINET_NIO=/home/markf/dev/nio/repos/fujinet-nio
# export FUJINET_NIO_LIB=/home/markf/dev/nio/repos/fujinet-nio-lib
# export NIO_APPS=/home/markf/dev/nio/repos/nio-apps
# export NIO_DOCS=/home/markf/dev/nio/repos/nio-docs
# export FUJINET_QEMU_MSDOS=/home/markf/dev/nio/repos/fujinet-qemu-msdos
# export FUJINET_MSDOS=/home/markf/dev/msdos/fujinet-msdos
# export FN_ROM=/home/markf/dev/nio/repos/fn-rom

# QEMU image creation. BASE_IMAGE is optional; fujinet-qemu-msdos defaults to
# $FUJINET_QEMU_MSDOS/msdos.qcow2 when it is not set.
# export BASE_IMAGE=/path/to/base-dos.qcow2
# export OUTPUT_IMAGE=$NIO_WORKSPACE/build/images/msdos-nio-apps.qcow2
# export APPS_MANIFEST=$FUJINET_QEMU_MSDOS/manifests/apps.yaml

# Runtime.
# export FUJINET_PORT=65504
# export FUJINET_NIO_BIN=$FUJINET_NIO/build/fujibus-tcp-debug/fujinet-nio
